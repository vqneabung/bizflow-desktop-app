<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:bizflow_desktop_app.ViewModels"
              xmlns:l="using:Jeek.Avalonia.Localization"
             x:Class="bizflow_desktop_app.Views.ProductFormView"
             x:DataType="vm:ProductFormViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="800">

            <!-- Header -->
            <StackPanel Spacing="4">
                <Button Content="←  Back"
                        Command="{ReflectionBinding CancelCommand}"
                        Background="Transparent"
                        Foreground="{DynamicResource AccentPurple}"
                        FontSize="14"
                        Padding="0"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{ReflectionBinding Title}"
                           FontSize="20"
                           FontWeight="Bold" />
            </StackPanel>

            <!-- Error banner -->
            <Border IsVisible="{ReflectionBinding HasError}"
                    Background="#FEF2F2"
                    CornerRadius="8" Padding="12"
                    BorderBrush="#FCA5A5" BorderThickness="1">
                <TextBlock Text="{ReflectionBinding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="13" />
            </Border>

            <!-- Form card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="12" Padding="24"
                    BorderBrush="#E5E7EB" BorderThickness="1">

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="16" ColumnSpacing="16">

                    <!-- Row 0: Name (full width) -->
                    <TextBox Grid.Row="0" Grid.ColumnSpan="2"
                             PlaceholderText="{l:Localize product.form.name}"
                             Text="{ReflectionBinding Name, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Row 1: Category + Primary Unit -->
                    <TextBox Grid.Row="1" Grid.Column="0"
                             PlaceholderText="{l:Localize product.form.category}"
                             Text="{ReflectionBinding Category, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             PlaceholderText="{l:Localize product.form.primaryUnit}"
                             Text="{ReflectionBinding PrimaryUnit, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Row 2: Price + Cost Price -->
                    <TextBox Grid.Row="2" Grid.Column="0"
                             PlaceholderText="{l:Localize product.form.price}"
                             Text="{ReflectionBinding PriceText, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />
                    <TextBox Grid.Row="2" Grid.Column="1"
                             PlaceholderText="{l:Localize product.form.costPrice}"
                             Text="{ReflectionBinding CostPriceText, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Row 3: Stock + Min Stock -->
                    <TextBox Grid.Row="3" Grid.Column="0"
                             PlaceholderText="{l:Localize product.form.stock}"
                             Text="{ReflectionBinding StockText, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />
                    <TextBox Grid.Row="3" Grid.Column="1"
                             PlaceholderText="{l:Localize product.form.minStock}"
                             Text="{ReflectionBinding MinStockText, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Row 4: Barcode (full width) -->
                    <TextBox Grid.Row="4" Grid.ColumnSpan="2"
                             PlaceholderText="{l:Localize product.form.barcode}"
                             Text="{ReflectionBinding Barcode, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Row 5: Image URL (full width) -->
                    <TextBox Grid.Row="5" Grid.ColumnSpan="2"
                             PlaceholderText="{l:Localize product.form.imageUrl}"
                             Text="{ReflectionBinding ImageUrl, Mode=TwoWay}"
                             FontSize="14" Padding="12,10" />

                    <!-- Divider -->
                    <Border Grid.Row="6" Grid.ColumnSpan="2"
                            Height="1" Background="#E5E7EB" />

                    <!-- Row 6: Action buttons -->
                    <StackPanel Grid.Row="7" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Spacing="12">
                        <Button Content="{ReflectionBinding SubmitText}"
                                Command="{ReflectionBinding SaveCommand}"
                                Background="{DynamicResource AccentPurple}"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="24,10"
                                CornerRadius="8" />
                        <Button Content="{l:Localize product.form.cancel}"
                                Command="{ReflectionBinding CancelCommand}"
                                Background="Transparent"
                                Foreground="Gray"
                                FontSize="14"
                                Padding="24,10"
                                CornerRadius="8" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{ReflectionBinding IsSubmitting}"
                         Height="3"
                         Foreground="{DynamicResource AccentPurple}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
