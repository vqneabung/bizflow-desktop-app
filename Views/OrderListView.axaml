<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:bizflow_desktop_app.ViewModels"
             xmlns:models="using:bizflow_desktop_app.Models"
             xmlns:l="using:Jeek.Avalonia.Localization"
             x:Class="bizflow_desktop_app.Views.OrderListView"
             x:DataType="vm:OrderListViewModel">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">

        <!-- ===== Filter bar ===== -->
        <Border Grid.Row="0" Padding="16"
                Background="{DynamicResource CardBg}" CornerRadius="12"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid ColumnDefinitions="*,200,Auto" ColumnSpacing="12">
                <ComboBox Grid.Column="0"
                          SelectedValue="{ReflectionBinding SelectedStatus}"
                          FontSize="14" Padding="12,8">
                    <ComboBoxItem Content="{l:Localize order.list.statusAll}" />
                    <ComboBoxItem Content="{l:Localize order.list.statusDraft}" Tag="DRAFT" />
                    <ComboBoxItem Content="{l:Localize order.list.statusCompleted}" Tag="COMPLETED" />
                    <ComboBoxItem Content="{l:Localize order.list.statusCancelled}" Tag="CANCELLED" />
                </ComboBox>

                <Button Grid.Column="2"
                        Content="{l:Localize order.list.create}"
                        Command="{ReflectionBinding CreateNewCommand}"
                        Background="{DynamicResource AccentPurple}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="20,10"
                        CornerRadius="8" />
            </Grid>
        </Border>

        <!-- ===== Loading indicator ===== -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     IsVisible="{ReflectionBinding IsLoading}"
                     VerticalAlignment="Bottom"
                     Height="3"
                     Foreground="{DynamicResource AccentPurple}" />

        <!-- ===== Content area ===== -->
        <Grid Grid.Row="1">
            <!-- Loading skeleton -->
            <StackPanel IsVisible="{ReflectionBinding IsLoading}" Spacing="8" Margin="0">
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
            </StackPanel>

            <!-- Error state -->
            <Border IsVisible="{ReflectionBinding HasError}"
                    Background="#FEF2F2"
                    CornerRadius="12" Padding="24"
                    BorderBrush="#FCA5A5" BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="{ReflectionBinding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="14"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Center" />
                    <Button Content="Retry"
                            Command="{ReflectionBinding RefreshCommand}"
                            HorizontalAlignment="Center"
                            Padding="24,8" />
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel IsVisible="{ReflectionBinding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="{l:Localize order.list.empty}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Order DataGrid -->
            <DataGrid x:CompileBindings="False"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource CardBg}"
                      CornerRadius="12"
                      RowHeight="48"
                      FontSize="13"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      DoubleTapped="OnRowDoubleTapped">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="{l:Localize order.detail.referenceNumber}" Binding="{Binding ReferenceNumber}" Width="*" />
                    <DataGridTextColumn Header="{l:Localize order.detail.total}" Binding="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" Width="150" />
                    <DataGridTemplateColumn Header="{l:Localize order.detail.status}" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="models:OrderSummaryResponse">
                                <TextBlock Text="{Binding Status}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="70" />
                    <DataGridTextColumn Header="{l:Localize order.detail.created}" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="160" />
                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="models:OrderSummaryResponse">
                                <Button Content="View"
                                        Click="OnViewButtonClick"
                                        Background="{DynamicResource AccentPurple}"
                                        Foreground="White"
                                        FontSize="12"
                                        Padding="12,4"
                                        CornerRadius="6" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ===== Pagination ===== -->
        <Border Grid.Row="2" Padding="8,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{ReflectionBinding TotalCount, StringFormat='Showing {0} orders'}"
                           FontSize="13"
                           Foreground="Gray"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="4">
                    <Button Content="{l:Localize product.list.prev}"
                            IsEnabled="{ReflectionBinding HasPrevious}"
                            Command="{ReflectionBinding GoToPageCommand}"
                            CommandParameter="{ReflectionBinding CurrentPage}"
                            FontSize="13"
                            Padding="12,6" />
                    <TextBlock Text="{ReflectionBinding CurrentPage, StringFormat='Page {0}'}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="8,0" />
                    <Button Content="{l:Localize product.list.next}"
                            IsEnabled="{ReflectionBinding HasNext}"
                            Command="{ReflectionBinding GoToPageCommand}"
                            CommandParameter="{ReflectionBinding CurrentPage}"
                            FontSize="13"
                            Padding="12,6" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
