<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:bizflow_desktop_app.ViewModels"
             x:Class="bizflow_desktop_app.Views.ProductListView"
             x:DataType="vm:ProductListViewModel">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">

        <!-- ===== Filter bar ===== -->
        <Border Grid.Row="0" Padding="16"
                Background="{DynamicResource CardBg}" CornerRadius="12"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid ColumnDefinitions="*,200,Auto" ColumnSpacing="12">
                <TextBox PlaceholderText="🔍  Search products..."
                         Text="{ReflectionBinding SearchText, Mode=TwoWay}"
                         FontSize="14" Padding="12,8" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{ReflectionBinding Categories}"
                          SelectedValue="{ReflectionBinding SelectedCategory}"
                          PlaceholderText="All categories"
                          FontSize="14" Padding="8" />

                <Button Grid.Column="2"
                        Content="+  Create Product"
                        Command="{ReflectionBinding CreateNewCommand}"
                        Background="{DynamicResource AccentPurple}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="20,10"
                        CornerRadius="8" />
            </Grid>
        </Border>

        <!-- ===== Loading indicator ===== -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     IsVisible="{ReflectionBinding IsLoading}"
                     VerticalAlignment="Bottom"
                     Height="3"
                     Foreground="{DynamicResource AccentPurple}" />

        <!-- ===== Content area ===== -->
        <Grid Grid.Row="1">
            <!-- Loading skeleton (visible only during loading) -->
            <StackPanel IsVisible="{ReflectionBinding IsLoading}" Spacing="8" Margin="0">
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
                <Border Background="#E5E7EB" Height="48" CornerRadius="8" />
            </StackPanel>

            <!-- Error state (visible only when error, not loading) -->
            <Border IsVisible="{ReflectionBinding HasError}"
                    Background="#FEF2F2"
                    CornerRadius="12" Padding="24"
                    BorderBrush="#FCA5A5" BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="{ReflectionBinding ErrorMessage}"
                               Foreground="#DC2626"
                               FontSize="14"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Center" />
                    <Button Content="Retry"
                            Command="{ReflectionBinding RefreshCommand}"
                            HorizontalAlignment="Center"
                            Padding="24,8" />
                </StackPanel>
            </Border>

            <!-- Empty state (visible when not loading, not error, no products) -->
            <StackPanel IsVisible="{ReflectionBinding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="No products found"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Try adjusting your search or create a new product."
                           FontSize="13"
                           Foreground="Gray"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Product DataGrid (always visible, shows data when loaded) -->
            <DataGrid ItemsSource="{ReflectionBinding Products}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource CardBg}"
                      CornerRadius="12"
                      RowHeight="48"
                      FontSize="13"
                      SelectionMode="Single"
                      DoubleTapped="OnRowDoubleTapped">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{ReflectionBinding Name}" Width="*" />
                    <DataGridTextColumn Header="Category" Binding="{ReflectionBinding Category}" Width="120" />
                    <DataGridTextColumn Header="Price" Binding="{ReflectionBinding Price, StringFormat='{}{0:N0} đ'}" Width="130" />
                    <DataGridTextColumn Header="Stock" Binding="{ReflectionBinding Stock}" Width="80" />
                    <DataGridTextColumn Header="Barcode" Binding="{ReflectionBinding Barcode}" Width="130" />
                    <DataGridTemplateColumn Header="Status" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="Active"
                                           Foreground="#059669"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="View"
                                        Click="OnViewButtonClick"
                                        Background="{DynamicResource AccentPurple}"
                                        Foreground="White"
                                        FontSize="12"
                                        Padding="12,4"
                                        CornerRadius="6" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ===== Pagination ===== -->
        <Border Grid.Row="2" Padding="8,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{ReflectionBinding TotalCount, StringFormat='Showing {0} products'}"
                           FontSize="13"
                           Foreground="Gray"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="4">
                    <Button Content="◀  Previous"
                            IsEnabled="{ReflectionBinding HasPrevious}"
                            Command="{ReflectionBinding GoToPageCommand}"
                            CommandParameter="{ReflectionBinding CurrentPage}"
                            FontSize="13"
                            Padding="12,6" />
                    <TextBlock Text="{ReflectionBinding CurrentPage, StringFormat='Page {0}'}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="8,0" />
                    <Button Content="Next  ▶"
                            IsEnabled="{ReflectionBinding HasNext}"                            Command="{ReflectionBinding GoToPageCommand}"
                            CommandParameter="{ReflectionBinding CurrentPage}"
                            FontSize="13"
                            Padding="12,6" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
