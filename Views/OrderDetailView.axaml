<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:bizflow_desktop_app.ViewModels"
             xmlns:models="using:bizflow_desktop_app.Models"
             xmlns:l="using:Jeek.Avalonia.Localization"
             xmlns:conv="using:Avalonia.Data.Converters"
             x:Class="bizflow_desktop_app.Views.OrderDetailView"
             x:DataType="vm:OrderDetailViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16">

            <!-- Back button -->
            <Button Content="{l:Localize order.detail.goBack}"
                    Command="{ReflectionBinding GoBackCommand}"
                    Background="Transparent"
                    Foreground="{DynamicResource AccentPurple}"
                    FontSize="14"
                    Padding="0"
                    HorizontalAlignment="Left" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{ReflectionBinding IsLoading}"
                         Height="3"
                         Foreground="{DynamicResource AccentPurple}" />

            <!-- Error -->
            <Border IsVisible="{ReflectionBinding HasError}"
                    Background="#FEF2F2"
                    CornerRadius="12" Padding="24">
                <TextBlock Text="{ReflectionBinding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="14" />
            </Border>

            <!-- Detail card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="12" Padding="24"
                    BorderBrush="#E5E7EB" BorderThickness="1">

                <Grid ColumnDefinitions="1.5*,2*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="16" ColumnSpacing="32">

                    <!-- Reference Number -->
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="{ReflectionBinding Order.ReferenceNumber}"
                               FontSize="24"
                               FontWeight="Bold" />

                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.status}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding StatusDisplay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentPurple}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.created}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding CreatedDate}" FontSize="15" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.total}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding TotalDisplay}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentPurple}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.paid}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding PaidDisplay}" FontSize="15" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.debt}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding DebtDisplay}" FontSize="15" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.updated}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{Binding UpdatedDate}" FontSize="15" />
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Spacing="4">
                        <TextBlock Text="{l:Localize order.detail.notes}" FontSize="12" Foreground="Gray" />
                        <TextBlock Text="{ReflectionBinding Order.Notes}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Row="5" Grid.ColumnSpan="2"
                            Height="1" Background="#E5E7EB" />

                    <!-- Items section -->
                    <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Spacing="8">
                        <TextBlock Text="{l:Localize order.detail.items}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />

                        <DataGrid x:CompileBindings="False"
                                  ItemsSource="{Binding Order.Items}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowHeight="40"
                                  FontSize="13"
                                  HeadersVisibility="Column"
                                  IsVisible="{Binding HasItems}">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100" />
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='{}{0:N0} đ'}" Width="120" />
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Row="7" Grid.ColumnSpan="2"
                            Height="1" Background="#E5E7EB" />

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="8" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Spacing="12">
                        <Button Content="{l:Localize order.detail.cancelOrder}"
                                Command="{ReflectionBinding CancelOrderCommand}"
                                Background="#FEF2F2"
                                Foreground="#DC2626"
                                FontSize="14"
                                Padding="20,10"
                                CornerRadius="8"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1" />
                        <Button Content="{l:Localize order.detail.downloadReceipt}"
                                Command="{ReflectionBinding DownloadReceiptCommand}"
                                IsEnabled="{ReflectionBinding !IsDownloading}"
                                Background="{DynamicResource AccentPurple}"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="20,10"
                                CornerRadius="8" />
                    </StackPanel>

                    <!-- Download status -->
                    <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Spacing="4">
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{ReflectionBinding IsDownloading}"
                                     Height="3"
                                     Foreground="{DynamicResource AccentPurple}" />
                        <TextBlock Text="{ReflectionBinding DownloadMessage}"
                                   FontSize="12"
                                   Foreground="#666"
                                   IsVisible="{ReflectionBinding DownloadMessage, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
